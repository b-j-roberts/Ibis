# Ibis Environment Variables
# Copy to .env and fill in values

# Starknet RPC endpoint (WSS preferred, HTTP fallback supported)
IBIS_RPC_URL=wss://starknet-mainnet.example.com

# Database configuration
IBIS_DB_USER=ibis
IBIS_DB_PASSWORD=ibis
IBIS_DB_NAME=ibis
IBIS_DB_HOST=localhost
IBIS_DB_PORT=5432

# API server
IBIS_API_HOST=0.0.0.0
IBIS_API_PORT=8080

# Indexer settings
IBIS_NETWORK=mainnet
IBIS_LOG_LEVEL=info
